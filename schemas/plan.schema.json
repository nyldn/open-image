{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nyldn/img/schemas/plan.schema.json",
  "title": "img plan",
  "type": "object",
  "required": ["schemaVersion", "request", "context", "delivery", "confirmation", "generation", "assets"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "request": {
      "type": "object",
      "required": ["prompt", "cwd", "createdAt"],
      "properties": {
        "prompt": { "type": "string" },
        "cwd": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "additionalProperties": false
    },
    "context": {
      "type": "object",
      "properties": {
        "projectRoot": { "type": ["string", "null"] },
        "configFiles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "assetType": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "delivery": {
      "type": "object",
      "required": ["mode", "requiresConfirmation"],
      "properties": {
        "mode": { "type": "string" },
        "requiresConfirmation": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "confirmation": {
      "type": "object",
      "required": ["planId", "requiresSiteEditConfirmation", "requiresProductionConfirmation"],
      "properties": {
        "planId": { "type": "string" },
        "requiresSiteEditConfirmation": { "type": "boolean" },
        "requiresProductionConfirmation": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "estimate": {
      "type": "object",
      "properties": {
        "images": { "type": "integer", "minimum": 1 },
        "maxCostUsd": { "type": ["number", "null"], "minimum": 0 }
      },
      "additionalProperties": false
    },
    "generation": {
      "type": "object",
      "required": ["provider", "model", "count", "outputDir"],
      "properties": {
        "provider": { "enum": ["openai", "gemini"] },
        "model": { "type": "string" },
        "count": { "type": "integer", "minimum": 1, "maximum": 12 },
        "outputDir": { "type": "string" }
      },
      "additionalProperties": false
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "filename", "prompt"],
        "properties": {
          "id": { "type": "string" },
          "filename": { "type": "string" },
          "prompt": { "type": "string" },
          "target": {
            "type": "object",
            "properties": {
              "kind": { "type": "string" },
              "file": { "type": "string" },
              "hint": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "recipes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "revision", "id"],
        "properties": {
          "source": { "type": "string" },
          "revision": { "type": "string" },
          "id": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
