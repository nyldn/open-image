{
  "name": "@nyldn/img",
  "version": "0.1.0",
  "description": "Claude Code and Codex plugin for generating images with OpenAI GPT Image 2 and Gemini 3.1 Flash Image Preview.",
  "type": "module",
  "bin": {
    "img": "./bin/img"
  },
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "validate": "node scripts/validate.mjs",
    "smoke": "node bin/img --dry-run --provider openai --prompt \"A minimal app icon\" && node bin/img --dry-run --provider gemini --prompt \"A minimal app icon\""
  },
  "keywords": [
    "claude-code-plugin",
    "codex-plugin",
    "image-generation",
    "gpt-image-2",
    "gemini",
    "nano-banana"
  ],
  "author": "nyldn",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nyldn/img.git"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    ".claude-plugin/",
    ".codex-plugin/",
    "bin/",
    "commands/",
    "docs/",
    "scripts/",
    "schemas/",
    "skills/",
    "src/",
    "templates/",
    "tests/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    ".env.example"
  ]
}
